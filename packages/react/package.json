{
  "name": "@micro-dnd/react",
  "version": "0.1.0",
  "description": "React adapter for micro-dnd",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@micro-dnd/core": "workspace:*"
  },
  "keywords": ["react", "dnd", "drag and drop", "sortable", "zero-reflow"],
  "license": "MIT"
}
